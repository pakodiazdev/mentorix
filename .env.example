# ===========================================
# Mentorix - Docker Compose Environment Variables
# ===========================================
# Copy this file to .env and adjust values as needed
# Docker Compose will automatically load variables from .env file

# ===========================================
# Local Development - Vue 3 Webapp Ports
# ===========================================
VITE_PORT=5173

# ===========================================
# Local Development - NestJS API Ports
# ===========================================
API_PORT=3000

# ===========================================
# Local Development - MongoDB Database
# ===========================================
# NOTE: These values are NOT sensitive as they are for local Docker containers
# - Containers are ephemeral and only accessible on your local machine
# - They enable automated setup without additional manual steps
# - Never used in production (use MONGO_PROD_* for production)
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DB=mentorix
MONGO_PORT=27017

# ===========================================
# Production - MongoDB Database (External)
# ===========================================
# Configure these for production deployment with external database
MONGO_PROD_URI=mongodb+srv://your_production_user:your_production_password@cluster.example.com/mentorix
MONGO_PROD_DB=mentorix

# ===========================================
# Mongo Express Configuration (DB Admin UI)
# ===========================================
MONGO_EXPRESS_PORT=8081

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRATION=3600
